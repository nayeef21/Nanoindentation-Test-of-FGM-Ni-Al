#Nanoindentation Test at Z direction of Ni-Al FGM materials  
# Script is under developing stage
#Loading unloading on Z axis
clear
# ---------------- Initialization ----------------
units           metal
dimension       3
boundary        p p s
atom_style      atomic
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes

# ---------------- Structure Input ----------------
# Read pre-built alloy structure
read_data       alloy.lmp

minimize 1.0e-6 1.0e-6 1000 10000

# ---------------- Groups Definition ----------------
region	1 block  INF INF INF INF INF 3 units box
group	lower region 1
region 2 block INF INF INF INF 3 6 units box
group thermo region 2
group mobile subtract all lower thermo
group newtonian subtract all lower

# ---------------- Potential----------------
pair_style      meam
pair_coeff      * * library.meam Ni Ti Al NiAlTi.meam Ni Al

# ---------------- Computes ----------------
compute	        new all temp
compute         peratom all pe/atom
compute         csym all centro/atom fcc
compute         disloc all displace/atom 

fix		1 lower setforce 0.0 0.0 0.0

# ---------------- Equilibration ----------------
reset_timestep	0
timestep        0.001
velocity newtonian create 300 12345 mom yes rot no 
thermo          100
thermo_style    custom step lx ly lz press pxx pyy pzz pe temp
#NVE + Temperature rescale (equilibration)
fix 4 newtonian nvt temp 300.0 300.0 0.01 drag 1.0
fix 6 all temp/rescale 100 300 300 1.0 0.5

run 50000
unfix 4 

# ---------- indentation -------------------------------------------
fix     2 thermo langevin 300.0 300.0 0.01 12345
fix     3 mobile nve
reset_timestep	0
timestep        0.001
variable xmid equal lx/2
variable ymid equal ly/2
variable z_initial   equal 67.2

variable indent_depth equal 22    # Target indentation depth (Angstrom)
variable indent_speed equal 0.1    # Indentation speed (Angstrom/ps)
variable retract_speed equal 0.1    # Retraction speed (Angstrom/ps)

# Calculate timing
variable indent_steps equal "v_indent_depth / (v_indent_speed * dt)"
variable retract_steps equal "v_indent_depth / (v_retract_speed * dt)"

# --- Output variables ---
variable fx equal f_7[1] 
variable fy equal f_7[2] 
variable fz equal f_7[3] 
variable step1 equal "step*dt" 
variable disp equal "step*dt*v_indent_speed"

dump myDump all atom 100 dump.final
dump_modify myDump sort id 

# PHASE 1: INDENTATION TO TARGET DEPTH
#-----------------------------------------------------------------------------
variable z equal "v_z_initial - v_indent_speed*step*dt"

fix 7 all indent 10.0 sphere ${xmid} ${ymid} v_z 20 units box
#fix 11 all move linear 0.0 -0.0002 0.0 units box # downward in y


# ---------------- Thermo & Output ---------------- 
thermo 100 
thermo_style custom step temp v_fz v_disp v_z 
thermo_modify lost warn 
fix output1 all print 100 "${disp} ${fz}  INDENT" file Indentation_log.txt screen no 

# Run until target depth is reached
run ${indent_steps}

# PHASE 2: RETRACTION
#-----------------------------------------------------------------------------
print "=== PHASE 2: RETRACTION ==="
unfix 7
unfix output1

variable z_retract equal "(v_z_initial - v_indent_depth) + v_retract_speed*(step - v_indent_steps)*dt"
variable disp_retract equal "v_indent_depth - (step - v_indent_steps)*dt*v_retract_speed"
fix 7 all indent 10.0 sphere ${xmid} ${ymid} v_z_retract 20 units box

#---------------- Thermo & Output ---------------- 
thermo 100 
thermo_style custom step temp v_fz v_disp_retract v_z_retract 
thermo_modify lost warn 
fix output3 all print 100 "${disp_retract} ${fz}  RETRACT" append Indentation_log.txt screen no


# Retract to original position
run ${retract_steps}

